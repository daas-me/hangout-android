<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Profile Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Avatar with camera overlay -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/avatar_bg"
                        android:clipToOutline="true" />

                    <!-- Initials fallback -->
                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:gravity="center"
                        android:textSize="32sp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/syne_bold"
                        android:background="@drawable/avatar_gradient_bg" />

                    <!-- Camera button -->
                    <ImageView
                        android:id="@+id/ivCameraOverlay"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/camera_btn_bg"
                        android:src="@drawable/ic_camera"
                        android:padding="7dp"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/syne_bold"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/purple_main"
                    android:fontFamily="@font/dm_sans"
                    android:layout_marginBottom="24dp" />

                <!-- Stats row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Hosting stat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/stat_bg_purple"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_calendar" android:layout_marginEnd="10dp"
                            app:tint="@color/purple_main" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Events Hosting"
                            android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="@font/dm_sans" />
                        <TextView android:id="@+id/tvHostingCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:fontFamily="@font/syne_bold" />
                    </LinearLayout>

                    <!-- Attending stat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/stat_bg_purple"
                        android:layout_marginBottom="8dp"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_users" android:layout_marginEnd="10dp"
                            app:tint="@color/purple_main" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Events Attending"
                            android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="@font/dm_sans" />
                        <TextView android:id="@+id/tvAttendingCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:fontFamily="@font/syne_bold" />
                    </LinearLayout>

                    <!-- Attendees stat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/stat_bg_pink"
                        android:padding="12dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_trending" android:layout_marginEnd="10dp"
                            app:tint="@color/pink_accent" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Total Attendees"
                            android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="@font/dm_sans" />
                        <TextView android:id="@+id/tvAttendeesCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/text_primary" android:fontFamily="@font/syne_bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Edit Profile button -->
                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Edit Profile"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/dm_sans"
                    android:background="@drawable/btn_ghost"
                    android:stateListAnimator="@null" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Account Settings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/syne_bold"
                    android:layout_marginBottom="12dp" />

                <!-- Personal Information row -->
                <include layout="@layout/item_settings_row"
                    android:id="@+id/rowPersonalInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginVertical="4dp"/>

                <!-- Change Password row -->
                <include layout="@layout/item_settings_row"
                    android:id="@+id/rowChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginVertical="4dp"/>

                <!-- Sign Out row -->
                <include layout="@layout/item_settings_row_danger"
                    android:id="@+id/rowSignOut"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/purple_main" />

    </LinearLayout>
</ScrollView>